@model List<CineBenavides.Models.Usuario>
@{ ViewData["Title"] = "Usuarios"; }

<h2>Usuarios</h2>

<a class="btn btn-success mb-3" href="/Usuario/Create">+ Nuevo Usuario</a>

<table class="table table-striped table-bordered">
    <thead class="table-dark">
        <tr>
            <th>Nombre</th>
            <th>Correo</th>
            <th>Rol</th>
            <th>Celular</th>
            <th>Acciones</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Nombre</td>
                <td>@item.Correo</td>
                <td>@item.Rol</td>
                <td>@item.Celular</td>
                <td>
                    <a class="btn btn-warning btn-sm" href="/Usuario/Edit/@item.Id">Editar</a>
                    <form action="/Usuario/Delete/@item.Id" method="post" style="display:inline"
                          onsubmit="return confirm('¿Seguro que desea eliminar este usuario?')">
                        <button type="submit" class="btn btn-danger btn-sm">Eliminar</button>
                    </form>
                </td>
            </tr>
        }
    </tbody>
</table>
