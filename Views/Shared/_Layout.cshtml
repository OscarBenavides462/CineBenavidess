<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - CineBenavides</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <style>
            .navbar {
                background: #1a1a2e !important;
            }

                .navbar .nav-link {
                    color: #ccc !important;
                }

                    .navbar .nav-link:hover {
                        color: #fff !important;
                    }

            .navbar-brand {
                color: #e63946 !important;
                font-weight: 700;
                font-size: 1.3rem;
            }

            .badge-rol {
                background: #e63946;
                color: #fff;
                border-radius: 20px;
                padding: 3px 12px;
                font-size: .8rem;
            }
    </style>
</head>
<body>

    @if (Context.Session.GetString("Usuario") != null)
    {
        <nav class="navbar navbar-expand-sm navbar-dark mb-4">
            <div class="container-fluid">

                <a class="navbar-brand" href="/Home/Index">CineBenavides</a>

                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navMenu">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="navMenu">
                    <ul class="navbar-nav me-auto">

                        <li class="nav-item">
                            <a class="nav-link" href="/Home/Index">Inicio</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="/Pelicula/Index">Cartelera</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="/Confiteria/Index">Confitería</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="/Reserva/MisReservas">Mis Reservas</a>
                        </li>

                        @if (Context.Session.GetString("Rol") == "Soporte" ||
                             Context.Session.GetString("Rol") == "Administrador")
                        {
                            <li class="nav-item">
                                <a class="nav-link" href="/Reserva/Index">Todas las Reservas</a>
                            </li>
                        }

                        @if (Context.Session.GetString("Rol") == "Administrador")
                        {
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle" href="#" data-bs-toggle="dropdown">
                                    Administrar
                                </a>
                                <ul class="dropdown-menu">
                                    <li><a class="dropdown-item" href="/Usuario/Index">Usuarios</a></li>
                                    <li><a class="dropdown-item" href="/Categoria/Index">Categorías</a></li>
                                    <li><a class="dropdown-item" href="/Sala/Index">Salas</a></li>
                                    <li><a class="dropdown-item" href="/Funcion/Index">Funciones</a></li>
                                    <li><a class="dropdown-item" href="/Pelicula/Index">Películas</a></li>
                                    <li><a class="dropdown-item" href="/Confiteria/Index">Confitería</a></li>
                                </ul>
                            </li>
                        }

                    </ul>

                    <div class="d-flex align-items-center gap-2">
                        <span class="badge-rol">@Context.Session.GetString("Rol")</span>
                        <span class="text-light" style="font-size:.9rem">
                            @Context.Session.GetString("Usuario")
                        </span>
                        <a href="/Login/Logout" class="btn btn-sm btn-outline-light ms-2">Salir</a>
                    </div>
                </div>

            </div>
        </nav>
    }

    <div class="container">
        <main>
            @RenderBody()
        </main>
    </div>

    <footer class="mt-5 py-3 border-top text-center text-muted" style="font-size:.85rem">
        &copy; 2026 CineBenavides
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery/3.6.0/jquery.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validate/1.19.3/jquery.validate.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validation-unobtrusive/3.2.12/jquery.validate.unobtrusive.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
