@model List<CineBenavides.Models.Confiteria>
@{ ViewData["Title"] = "Confitería"; }

<div class="container mt-4">
    @if (TempData["Mensaje"] != null)
    {
        <div class="alert alert-success">@TempData["Mensaje"]</div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger">@TempData["Error"]</div>
    }

    <h2 class="mb-4 text-center">Confitería 🍿</h2>

    @if (Context.Session.GetString("Rol") == "Administrador")
    {
        <a class="btn btn-success mb-3" href="/Confiteria/Create">+ Nuevo Producto</a>
    }

    @if (!Model.Any())
    {
        <p class="text-muted text-center py-4">No hay productos registrados en confitería.</p>
    }

    <div class="row">
        @foreach (var item in Model)
        {
            <div class="col-md-3 mb-4">
                <div class="card h-100 shadow">

                    @if (item.ImagenUrl != null)
                    {
                        <img src="@item.ImagenUrl" class="card-img-top" style="height:200px;object-fit:cover" />
                    }
                    else
                    {
                        <div class="bg-secondary d-flex align-items-center justify-content-center" style="height:200px">
                            <span class="text-white" style="font-size:3rem">🍿</span>
                        </div>
                    }

                    <div class="card-body d-flex flex-column">
                        <h5 class="card-title">@item.Nombre</h5>
                        <p class="card-text text-muted" style="font-size:.9rem">@item.Descripcion</p>
                        <p class="card-text">
                            <span class="fw-bold text-danger fs-5">$@item.Precio.ToString("N0")</span><br />
                            <small class="text-muted">Stock: @item.Stock unidades</small>
                        </p>

                        @if (Context.Session.GetString("Rol") == "Administrador")
                        {
                            <div class="mb-2">
                                <a href="/Confiteria/Edit/@item.Id" class="btn btn-warning btn-sm">Editar</a>
                                <form action="/Confiteria/Delete/@item.Id" method="post" style="display:inline"
                                      onsubmit="return confirm('¿Seguro que desea eliminar este producto?')">
                                    <button type="submit" class="btn btn-danger btn-sm">Eliminar</button>
                                </form>
                            </div>
                        }

                        <hr class="mt-auto" />

                        @if (item.Stock > 0)
                        {
                            <span class="badge bg-success mb-2">Disponible</span>
                            
                            <a href="/Pelicula" class="btn btn-primary w-100" >Agregar al pedido</a>
                        }
                        else
                        {
                            <div class="alert alert-warning text-center py-1 mb-2" style="font-size:.85rem">
                                Producto agotado
                            </div>
                            <button class="btn btn-secondary w-100" disabled>Sin stock</button>
                        }
                    </div>

                </div>
            </div>
        }
    </div>
</div>
