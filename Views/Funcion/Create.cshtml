@model CineBenavides.Models.Funcion
@{ 
    ViewData["Title"] = "Nueva Función";
    var minFecha = DateTime.Now.ToString("yyyy-MM-ddTHH:mm");
}

<div class="container mt-4" style="max-width:600px">
    <h2 class="mb-4">🎟️ Nueva Función</h2>

    <form asp-action="Create" method="post">
        <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

        <div class="mb-3">
            <label class="form-label fw-semibold">Película *</label>
            <select asp-for="PeliculaId" class="form-select" asp-items="ViewBag.Peliculas">
                <option value="">-- Seleccione una película --</option>
            </select>
            <span asp-validation-for="PeliculaId" class="text-danger small"></span>
        </div>

        <div class="mb-3">
            <label class="form-label fw-semibold">Sala *</label>
            <select asp-for="SalaId" class="form-select" asp-items="ViewBag.Salas">
                <option value="">-- Seleccione una sala --</option>
            </select>
            <span asp-validation-for="SalaId" class="text-danger small"></span>
        </div>

        <div class="row">
            <div class="col-md-7 mb-3">
                <label class="form-label fw-semibold">Fecha y Hora *</label>
                <input asp-for="FechaHora" class="form-control" type="datetime-local"
                       min="@minFecha" />
                <span asp-validation-for="FechaHora" class="text-danger small"></span>
            </div>
            <div class="col-md-5 mb-3">
                <label class="form-label fw-semibold">Precio *</label>
                <div class="input-group">
                    <span class="input-group-text">$</span>
                    <input asp-for="Precio" class="form-control" type="number" step="500" min="0" />
                </div>
                <span asp-validation-for="Precio" class="text-danger small"></span>
            </div>
        </div>

        <div class="d-flex gap-2 mt-2">
            <button type="submit" class="btn btn-success px-4">💾 Guardar</button>
            <a href="/Funcion/Index" class="btn btn-secondary">Volver</a>
        </div>
    </form>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}
