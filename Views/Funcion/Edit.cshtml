@model CineBenavides.Models.Funcion
@{ ViewData["Title"] = "Editar Función"; }

<h2>Editar Función</h2>

<form asp-action="Edit" method="post">

    <input type="hidden" asp-for="Id" />

    <div asp-validation-summary="All" class="text-danger mb-3"></div>

    <div class="mb-3">
        <label>Película</label>
        <select asp-for="PeliculaId" class="form-control" asp-items="ViewBag.Peliculas">
            <option value="">-- Seleccione una película --</option>
        </select>
        <span asp-validation-for="PeliculaId" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label>Sala</label>
        <select asp-for="SalaId" class="form-control" asp-items="ViewBag.Salas">
            <option value="">-- Seleccione una sala --</option>
        </select>
        <span asp-validation-for="SalaId" class="text-danger"></span>
    </div>

    <div class="row">
        <div class="col-md-6 mb-3">
            <label>Fecha y Hora</label>
            <input asp-for="FechaHora" class="form-control" type="datetime-local" />
            <span asp-validation-for="FechaHora" class="text-danger"></span>
        </div>

        <div class="col-md-6 mb-3">
            <label>Precio</label>
            <div class="input-group">
                <span class="input-group-text">$</span>
                <input asp-for="Precio" class="form-control" type="number" step="500" />
            </div>
            <span asp-validation-for="Precio" class="text-danger"></span>
        </div>
    </div>

    <button type="submit" class="btn btn-primary">Actualizar</button>
    <a href="/Funcion/Index" class="btn btn-secondary">Volver</a>

</form>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}
