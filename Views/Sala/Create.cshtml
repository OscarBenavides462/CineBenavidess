@model CineBenavides.Models.Sala
@{ ViewData["Title"] = "Nueva Sala"; }

<h2>Nueva Sala</h2>

<form asp-action="Create" method="post">

    <div asp-validation-summary="All" class="text-danger mb-3"></div>

    <div class="mb-3">
        <label>Nombre</label>
        <input asp-for="Nombre" class="form-control" placeholder="Ej: Sala 1, Sala VIP..." />
        <span asp-validation-for="Nombre" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label>Capacidad (número de asientos)</label>
        <input asp-for="Capacidad" class="form-control" type="number" />
        <span asp-validation-for="Capacidad" class="text-danger"></span>
    </div>

    <button type="submit" class="btn btn-success">Guardar</button>
    <a href="/Sala/Index" class="btn btn-secondary">Volver</a>

</form>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}
