@model List<CineBenavides.Models.Pelicula>
@{ ViewData["Title"] = "Cartelera"; }

<div class="container mt-4">
    <h2 class="mb-4 text-center">🎬 Cartelera</h2>

    @if (Context.Session.GetString("Rol") == "Administrador")
    {
        <a class="btn btn-success mb-3" href="/Pelicula/Create">+ Nueva Película</a>
    }

    @if (!Model.Any())
    {
        <p class="text-muted text-center py-4">No hay películas en cartelera actualmente.</p>
    }

    <div class="row">
        @foreach (var item in Model)
        {
            <div class="col-md-3 mb-4">
                <div class="card h-100 shadow">

                    @if (item.PosterUrl != null)
                    {
                        <img src="@item.PosterUrl" class="card-img-top"
                             style="height:320px;object-fit:cover;cursor:pointer"
                             data-bs-toggle="modal" data-bs-target="#modalPoster_@item.Id" />
                    }
                    else
                    {
                        <div class="bg-dark d-flex align-items-center justify-content-center"
                             style="height:320px">
                            <span class="text-white" style="font-size:4rem">🎬</span>
                        </div>
                    }

                    <div class="card-body d-flex flex-column">
                        <h5 class="card-title mb-1">@item.Titulo</h5>
                        <p class="text-muted mb-1" style="font-size:.85rem">
                            <span class="badge bg-secondary">@item.Categoria?.Nombre</span>
                            <span class="badge bg-info text-dark">@item.Clasificacion</span>
                        </p>
                        <p class="card-text" style="font-size:.88rem">
                            🎥 <strong>Dir.:</strong> @item.Director<br />
                            ⏱ @item.DuracionMinutos min
                        </p>
                        <p class="text-muted mt-auto" style="font-size:.82rem;overflow:hidden;display:-webkit-box;-webkit-line-clamp:3;-webkit-box-orient:vertical;">
                            @item.Descripcion
                        </p>

                        @if (Context.Session.GetString("Rol") == "Administrador")
                        {
                            <div class="mt-2">
                                <a href="/Pelicula/Edit/@item.Id" class="btn btn-warning btn-sm">Editar</a>
                                <form action="/Pelicula/Delete/@item.Id" method="post" style="display:inline"
                                      onsubmit="return confirm('¿Seguro que desea eliminar esta película?')">
                                    <button type="submit" class="btn btn-danger btn-sm">Eliminar</button>
                                </form>
                            </div>
                        }

                        <a href="/Funcion/Index" class="btn btn-primary w-100 mt-2">Ver funciones</a>
                    </div>
                </div>
            </div>

            @* Modal para ver el póster en grande *@
            @if (item.PosterUrl != null)
            {
                <div class="modal fade" id="modalPoster_@item.Id" tabindex="-1">
                    <div class="modal-dialog modal-dialog-centered modal-lg">
                        <div class="modal-content bg-dark border-0">
                            <div class="modal-header border-0 pb-0">
                                <h5 class="modal-title text-white">@item.Titulo</h5>
                                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                            </div>
                            <div class="modal-body text-center p-2">
                                <img src="@item.PosterUrl" class="img-fluid rounded" style="max-height:80vh;object-fit:contain" />
                            </div>
                        </div>
                    </div>
                </div>
            }
        }
    </div>
</div>
